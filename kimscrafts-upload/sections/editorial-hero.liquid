<section class="kc-hero">
  <div class="kc-wrap">
    {%- if section.settings.eyebrow != blank -%}
      <div class="kc-hero__eyebrow kc-eyebrow kc-reveal">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="kc-hero__title kc-reveal" data-delay="1">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="kc-hero__sub kc-reveal" data-delay="2">{{ section.settings.subtext }}</p>
    {%- endif -%}
    <div class="kc-hero__divider kc-reveal" data-delay="3"></div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Handmade · Small-batch · Est. 2024"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Wrap words in <em> tags to style them in tan italic.",
      "default": "<p>Leather book wallets, <em>stitched by hand.</em></p>"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub-text",
      "default": "Four covers. One honest wallet. Cut from full-grain leather, saddle-stitched in small runs, and sent out in a cloth sleeve that's worth keeping."
    }
  ],
  "presets": [
    { "name": "Editorial hero" }
  ]
}
{% endschema %}
