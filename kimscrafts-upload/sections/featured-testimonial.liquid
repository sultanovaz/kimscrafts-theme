<section class="kc-ftest" style="background: {{ section.settings.bg_color | default: 'var(--kc-navy)' }}; color: {{ section.settings.text_color | default: 'var(--kc-cream)' }};">
  <div class="kc-wrap--narrow">
    <div class="kc-ftest__inner kc-reveal">
      <div class="kc-ftest__marks" aria-hidden="true">"</div>
      <blockquote class="kc-ftest__quote">{{ section.settings.quote }}</blockquote>
      <div class="kc-ftest__meta">
        {%- if section.settings.author_image != blank -%}
          <div class="kc-ftest__avatar"><img src="{{ section.settings.author_image | image_url: width: 120 }}" alt=""></div>
        {%- endif -%}
        <div>
          <div class="kc-ftest__author">{{ section.settings.author }}</div>
          {%- if section.settings.author_detail != blank -%}
            <div class="kc-ftest__detail">{{ section.settings.author_detail }}</div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured testimonial",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color" },
    { "type": "color", "id": "text_color", "label": "Text color" },
    { "type": "textarea", "id": "quote", "label": "Quote", "default": "I've carried a lot of wallets. This one's going with me until it's nothing but patina and memory." },
    { "type": "text", "id": "author", "label": "Author", "default": "Marcus H." },
    { "type": "text", "id": "author_detail", "label": "Author detail", "default": "Carried for 14 months" },
    { "type": "image_picker", "id": "author_image", "label": "Author image (optional)" }
  ],
  "presets": [{ "name": "Featured testimonial" }]
}
{% endschema %}
