<section class="kc-404">
  <div class="kc-wrap--narrow">
    <div class="kc-404__inner kc-reveal">
      <div class="kc-404__num">
        <span>4</span>
        <span class="kc-404__zero">0</span>
        <span>4</span>
      </div>
      <div class="kc-eyebrow" style="margin-top: 20px;">Page not found</div>
      <h1 class="kc-404__title">The leather's fine. <em>This page isn't.</em></h1>
      <p class="kc-404__text">The page you were looking for has gone missing. Try heading back to the shop — everything worth finding is there.</p>
      <div class="kc-404__actions">
        <a href="/" class="kc-btn kc-btn--secondary">Home</a>
        <a href="/collections/all" class="kc-btn kc-btn--primary">Shop the collection →</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "404 page" }
{% endschema %}
