<section class="kc-cart">
  <div class="kc-wrap">
    <header class="kc-cart__head">
      <div class="kc-eyebrow">Your bag</div>
      <h1 class="kc-cart__title">{{ 'sections.cart.title' | t }}</h1>
    </header>
  </div>

  {%- if cart.item_count > 0 -%}
    {%- assign free_ship_threshold = section.settings.free_ship_threshold | times: 100 -%}
    {%- assign progress_pct = cart.total_price | times: 100.0 | divided_by: free_ship_threshold -%}
    {%- if progress_pct > 100 -%}{%- assign progress_pct = 100 -%}{%- endif -%}
    {%- assign remaining = free_ship_threshold | minus: cart.total_price -%}

    {%- if section.settings.show_shipping_bar and free_ship_threshold > 0 -%}
      <div class="kc-wrap">
        <div class="kc-ship-bar">
          {%- if remaining > 0 -%}
            <div class="kc-ship-bar__text">Add <strong>{{ remaining | money }}</strong> more for free shipping</div>
          {%- else -%}
            <div class="kc-ship-bar__text kc-ship-bar__text--done">✓ You've unlocked free shipping</div>
          {%- endif -%}
          <div class="kc-ship-bar__track"><div class="kc-ship-bar__fill" style="width: {{ progress_pct }}%"></div></div>
        </div>
      </div>
    {%- endif -%}

    <div class="kc-cart__grid">
      <div class="kc-cart__items">
        <form action="/cart" method="post" id="kc-cart-form">
          {%- for item in cart.items -%}
            <div class="kc-cart-item" data-cart-update data-key="{{ item.key }}">
              <a href="{{ item.url }}" class="kc-cart-item__img">
                {%- if item.image != blank -%}
                  <img src="{{ item.image | image_url: width: 280 }}" alt="{{ item.image.alt | escape }}" width="280" height="350" loading="lazy">
                {%- endif -%}
              </a>
              <div>
                <a href="{{ item.url }}">
                  <h3 class="kc-cart-item__title">{{ item.product.title }}</h3>
                </a>
                {%- unless item.product.has_only_default_variant -%}
                  <div class="kc-cart-item__variant">{{ item.variant.title }}</div>
                {%- endunless -%}
                {%- if item.properties.size > 0 -%}
                  <div class="kc-cart-item__props">
                    {%- for p in item.properties -%}
                      {%- unless p.last == blank or p.first contains '_' -%}
                        <span>{{ p.first }}: <strong>{{ p.last }}</strong></span>
                      {%- endunless -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
                <div class="kc-cart-item__price">{{ item.final_line_price | money }}</div>

                <div class="kc-cart-item__controls">
                  <div class="kc-qty" data-qty>
                    <button type="button" data-qty-minus aria-label="Decrease">−</button>
                    <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" inputmode="numeric">
                    <button type="button" data-qty-plus aria-label="Increase">+</button>
                  </div>
                  <a href="#" class="kc-cart-item__remove" data-cart-remove data-key="{{ item.key }}">Remove</a>
                </div>
              </div>
              <div class="kc-cart-item__total">
                {{ item.final_line_price | money }}
              </div>
            </div>
          {%- endfor -%}

          {%- if section.settings.show_gift_note -%}
            <div class="kc-gift-note">
              <label class="kc-gift-note__toggle">
                <input type="checkbox" data-gift-toggle>
                <span class="kc-gift-note__icon">
                  <svg viewBox="0 0 24 24" fill="none"><path d="M20 12v9H4v-9M2 7h20v5H2zM12 22V7M12 7s-3-3-5-3-3 1.5-3 3 1.5 3 3 3M12 7s3-3 5-3 3 1.5 3 3-1.5 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
                </span>
                <span class="kc-gift-note__label">Add a gift note <em>(free, hand-written)</em></span>
              </label>
              <textarea name="note" class="kc-gift-note__field" placeholder="Write your message here — we'll include it on a small card." maxlength="500">{{ cart.note }}</textarea>
            </div>
          {%- endif -%}
        </form>
      </div>

      <aside class="kc-cart-summary">
        <h3>Summary</h3>
        <div class="kc-cart-summary__row">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        {%- if cart.cart_level_discount_applications.size > 0 -%}
          {%- for discount in cart.cart_level_discount_applications -%}
            <div class="kc-cart-summary__row">
              <span>{{ discount.title }}</span>
              <span>−{{ discount.total_allocated_amount | money }}</span>
            </div>
          {%- endfor -%}
        {%- endif -%}
        <div class="kc-cart-summary__row">
          <span>Shipping</span>
          <span>{% if cart.total_price >= free_ship_threshold %}Free{% else %}Calculated at checkout{% endif %}</span>
        </div>
        <div class="kc-cart-summary__row kc-cart-summary__row--total">
          <span>Total</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <form action="/cart" method="post" novalidate>
          <button type="submit" name="checkout" class="kc-btn kc-btn--primary kc-btn--full">
            Checkout securely →
          </button>
        </form>
        {%- if settings.show_taxes_note -%}
          <p class="kc-cart-summary__note">Taxes calculated at checkout. All wallets made to order in our studio.</p>
        {%- endif -%}

        <div class="kc-cart-trust">
          <div class="kc-cart-trust__item">
            <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="6" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M7 10h2M7 14h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
            <span>Secure checkout</span>
          </div>
          <div class="kc-cart-trust__item">
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l8 3v7c0 5-3 8-8 9-5-1-8-4-8-9V6l8-3z" stroke="currentColor" stroke-width="1.4"/></svg>
            <span>30-day returns</span>
          </div>
          <div class="kc-cart-trust__item">
            <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h13v11H3zM16 10h5l2 3v4h-7" stroke="currentColor" stroke-width="1.4"/></svg>
            <span>Free US shipping over ${{ section.settings.free_ship_threshold }}</span>
          </div>
        </div>
      </aside>
    </div>
  {%- else -%}
    <div class="kc-cart-empty">
      <div class="kc-cart-empty__icon">
        <svg viewBox="0 0 64 64" fill="none"><path d="M14 18h36l-3 34a4 4 0 0 1-4 3.6H21a4 4 0 0 1-4-3.6L14 18zM22 18v-3a8 8 0 0 1 16 0v3" stroke="currentColor" stroke-width="1.4"/></svg>
      </div>
      <h2>Your bag is empty.</h2>
      <p>Nothing in there yet. Let's find you something worth carrying.</p>
      <a href="/collections/all" class="kc-btn kc-btn--primary">Shop the collection →</a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Cart",
  "settings": [
    { "type": "checkbox", "id": "show_shipping_bar", "label": "Show free-shipping progress bar", "default": true },
    { "type": "number", "id": "free_ship_threshold", "label": "Free shipping threshold ($)", "default": 75 },
    { "type": "checkbox", "id": "show_gift_note", "label": "Show gift note field", "default": true }
  ]
}
{% endschema %}
