<section class="kc-social">
  <div class="kc-wrap">
    <div class="kc-social__head">
      {%- if section.settings.eyebrow != blank -%}<div class="kc-eyebrow kc-reveal">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="kc-social__title kc-reveal" data-delay="1">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.handle != blank -%}
        <a href="{{ section.settings.handle_url | default: settings.social_instagram }}" target="_blank" rel="noopener" class="kc-social__handle kc-reveal" data-delay="2">{{ section.settings.handle }} →</a>
      {%- endif -%}
    </div>
    <div class="kc-social__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="kc-social__tile kc-reveal" data-delay="{{ forloop.index0 | modulo: 4 }}" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.alt | default: 'Social post' | escape }}" loading="lazy">
          {%- else -%}
            <div style="aspect-ratio:1; background:var(--kc-cream);"></div>
          {%- endif -%}
          <div class="kc-social__overlay">
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" fill="currentColor"/></svg>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the community" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Carried in the <em>wild.</em></p>" },
    { "type": "text", "id": "handle", "label": "Handle / CTA", "default": "Follow @kimscrafts" },
    { "type": "url", "id": "handle_url", "label": "Handle link" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "url", "id": "link", "label": "Link (post URL)" }
      ]
    }
  ],
  "presets": [{
    "name": "Social grid",
    "blocks": [
      { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" },
      { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" }
    ]
  }]
}
{% endschema %}
