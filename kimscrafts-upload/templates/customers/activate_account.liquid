<section class="kc-customer">
  <h1>{{ 'customer.activate_account.title' | t }}</h1>
  <p class="kc-customer__sub">{{ 'customer.activate_account.subtext' | t }}</p>

  {%- form 'activate_customer_password' -%}
    {%- if form.errors -%}
      <div class="kc-notif kc-notif--error">
        <ul style="margin:0; padding-left:20px;">
          {%- for error in form.errors -%}<li>{{ form.errors.messages[error] }}</li>{%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
    <div class="kc-form-row">
      <label class="kc-label" for="ActivatePassword">{{ 'customer.activate_account.password' | t }}</label>
      <input type="password" name="customer[password]" id="ActivatePassword" class="kc-field" autocomplete="new-password" required>
    </div>
    <div class="kc-form-row">
      <label class="kc-label" for="ActivatePasswordConfirm">{{ 'customer.activate_account.password_confirm' | t }}</label>
      <input type="password" name="customer[password_confirmation]" id="ActivatePasswordConfirm" class="kc-field" autocomplete="new-password" required>
    </div>
    <div style="display:flex; gap:12px;">
      <button type="submit" class="kc-btn kc-btn--primary" style="flex:1;">{{ 'customer.activate_account.submit' | t }}</button>
      <button type="submit" name="decline" class="kc-btn kc-btn--secondary">{{ 'customer.activate_account.cancel' | t }}</button>
    </div>
  {%- endform -%}
</section>
