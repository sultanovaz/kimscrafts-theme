<section class="kc-customer kc-customer--wide">
  <div class="kc-eyebrow" style="text-align:center; margin-bottom:12px;">{{ 'customer.order.title' | t: name: order.name }}</div>
  <h1 style="text-align:center;">{{ order.name }}</h1>
  <p style="text-align:center; color:var(--kc-muted); margin-bottom:40px;">{{ 'customer.order.date_html' | t: date: order.created_at | date: format: 'date_at_time' }}</p>

  <div style="margin-bottom:32px;">
    <a href="{{ routes.account_url }}" class="kc-link">← {{ 'customer.account.return' | t }}</a>
  </div>

  <div style="background:var(--kc-cream); border-radius:var(--kc-r-md); padding:24px; margin-bottom:32px;">
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(160px, 1fr)); gap:20px; font-size:14px;">
      <div><div class="kc-eyebrow" style="margin-bottom:6px;">{{ 'customer.order.payment_status' | t }}</div>{{ order.financial_status_label }}</div>
      <div><div class="kc-eyebrow" style="margin-bottom:6px;">{{ 'customer.order.fulfillment_status' | t }}</div>{{ order.fulfillment_status_label }}</div>
      <div><div class="kc-eyebrow" style="margin-bottom:6px;">{{ 'customer.order.total' | t }}</div>{{ order.total_price | money }}</div>
    </div>
  </div>

  <table style="width:100%; border-collapse:collapse; font-size:14px;">
    <thead>
      <tr style="border-bottom:1px solid var(--kc-line);">
        <th style="text-align:left; padding:12px 0;">{{ 'customer.order.product' | t }}</th>
        <th style="text-align:right; padding:12px 0;">{{ 'customer.order.price' | t }}</th>
        <th style="text-align:right; padding:12px 0;">{{ 'customer.order.quantity' | t }}</th>
        <th style="text-align:right; padding:12px 0;">{{ 'customer.order.total' | t }}</th>
      </tr>
    </thead>
    <tbody>
      {%- for line_item in order.line_items -%}
        <tr style="border-bottom:1px solid var(--kc-line);">
          <td style="padding:16px 0;">
            <div style="font-weight:500;">{{ line_item.title }}</div>
            {%- if line_item.sku -%}<div style="color:var(--kc-muted); font-size:12px;">SKU: {{ line_item.sku }}</div>{%- endif -%}
          </td>
          <td style="text-align:right;">{{ line_item.price | money }}</td>
          <td style="text-align:right;">{{ line_item.quantity }}</td>
          <td style="text-align:right;">{{ line_item.final_line_price | money }}</td>
        </tr>
      {%- endfor -%}
    </tbody>
    <tfoot>
      <tr><td colspan="3" style="text-align:right; padding-top:16px;">{{ 'customer.order.subtotal' | t }}</td><td style="text-align:right; padding-top:16px;">{{ order.line_items_subtotal_price | money }}</td></tr>
      {%- for shipping_method in order.shipping_methods -%}
        <tr><td colspan="3" style="text-align:right;">{{ 'customer.order.shipping' | t }} ({{ shipping_method.title }})</td><td style="text-align:right;">{{ shipping_method.price | money }}</td></tr>
      {%- endfor -%}
      <tr style="font-family:var(--kc-f-display); font-size:18px;"><td colspan="3" style="text-align:right; padding:16px 0;">{{ 'customer.order.total' | t }}</td><td style="text-align:right;">{{ order.total_price | money }}</td></tr>
    </tfoot>
  </table>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-top:40px;">
    <div style="padding:24px; background:var(--kc-cream); border-radius:var(--kc-r-md);">
      <h3 class="kc-eyebrow" style="margin-bottom:12px;">{{ 'customer.order.billing_address' | t }}</h3>
      <address style="font-style:normal; font-size:14px; line-height:1.7;">{{ order.billing_address | format_address }}</address>
    </div>
    <div style="padding:24px; background:var(--kc-cream); border-radius:var(--kc-r-md);">
      <h3 class="kc-eyebrow" style="margin-bottom:12px;">{{ 'customer.order.shipping_address' | t }}</h3>
      <address style="font-style:normal; font-size:14px; line-height:1.7;">{{ order.shipping_address | format_address }}</address>
    </div>
  </div>
</section>
