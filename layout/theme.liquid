<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=5">
    <meta name="theme-color" content="{{ settings.color_bg | default: '#FBFAF7' }}">
    <link rel="canonical" href="{{ canonical_url }}">

<link rel="icon" type="image/png" href="{{ 'favicon.jpg' | asset_url }}">


    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {%- capture _title -%}
        {{ page_title }}
        {%- if current_tags -%}
          {%- assign _tag_list = current_tags | join: ', ' -%}
           &ndash; Tagged "{{ _tag_list }}"
        {%- endif -%}
        {%- if current_page and current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
        {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
      {%- endcapture -%}
      {{ _title | strip }}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    {%- comment -%} Fonts — Fraunces (display) + DM Sans (body) {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,400&family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..700,30..100;1,9..144,300..700,30..100&display=swap" rel="stylesheet">

    {{ 'theme.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      window.Shopify = window.Shopify || {};
      window.Shopify.routes = {root: '{{ routes.root_url | append: "/" | replace: "//", "/" }}'};
      window.Shopify.locale = '{{ request.locale.iso_code }}';
      window.Shopify.currency = { active: '{{ cart.currency.iso_code }}', rate: '{{ localization.market.handle }}' };
    </script>
  </head>

  <body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.name | handle }}-{{ template.suffix }}{% endif %}">
    <a class="skip-to-content-link" href="#MainContent">{{ 'general.accessibility.skip_to_text' | t }}</a>

    {% sections 'header-group' %}

    <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {{ 'theme.js' | asset_url | script_tag }}

    {%- if request.page_type contains 'customers/' -%}
      <script src="{{ 'shopify_common.js' | shopify_asset_url }}" defer></script>
    {%- endif -%}
  </body>
</html>
