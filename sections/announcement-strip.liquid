<section class="kc-strip" style="background: {{ section.settings.bg_color | default: 'var(--kc-tan)' }}; color: {{ section.settings.text_color | default: 'var(--kc-cream)' }};">
  <div class="kc-wrap">
    <div class="kc-strip__inner">
      <div class="kc-strip__text">
        {%- if section.settings.heading != blank -%}
          <span class="kc-strip__heading">{{ section.settings.heading }}</span>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <span class="kc-strip__sub">{{ section.settings.subtext }}</span>
        {%- endif -%}
      </div>
      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="kc-strip__cta">{{ section.settings.cta_label }} →</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Announcement strip",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background" },
    { "type": "color", "id": "text_color", "label": "Text color" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Holiday orders" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Order by Dec 15 for guaranteed delivery" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop now" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "presets": [{ "name": "Announcement strip" }]
}
{% endschema %}
