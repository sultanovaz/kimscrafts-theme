{%- liquid
  assign cols = section.settings.columns | default: 4
  assign cols_m = section.settings.columns_mobile | default: 2
  assign lim = section.settings.limit | default: 8
  assign coll_handle = section.settings.collection
  assign has_coll = false
  if coll_handle != blank
    assign coll = collections[coll_handle]
    if coll != blank and coll.products_count > 0
      assign has_coll = true
    endif
  endif
-%}

<section class="kc-grid-section">
  <div class="kc-wrap">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="kc-grid__header">
        {%- if section.settings.subheading != blank -%}
          <span class="kc-grid__eyebrow">{{ section.settings.subheading }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="kc-grid__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="kc-grid" style="--cols: {{ cols }}; --cols-mobile: {{ cols_m }};">
      {%- if has_coll -%}
        {%- for product in coll.products limit: lim -%}
          <a class="kc-pcard" href="{{ product.url }}">
            <div class="kc-pcard__media">
              {%- if product.featured_image != blank -%}
                <img src="{{ product.featured_image | image_url: width: 800 }}"
                     alt="{{ product.featured_image.alt | default: product.title | escape }}"
                     loading="lazy"
                     width="800" height="800">
              {%- endif -%}
              {%- if product.available == false -%}
                <span class="kc-pcard__badge">Sold out</span>
              {%- elsif product.compare_at_price > product.price -%}
                <span class="kc-pcard__badge kc-pcard__badge--sale">Sale</span>
              {%- endif -%}
            </div>
            <div class="kc-pcard__body">
              <h3 class="kc-pcard__name">{{ product.title }}</h3>
              <div class="kc-pcard__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="kc-pcard__price-sale">{{ product.price | money }}</span>
                  <span class="kc-pcard__price-compare">{{ product.compare_at_price | money }}</span>
                {%- else -%}
                  <span>{{ product.price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="kc-pcard kc-pcard--placeholder">
            <div class="kc-pcard__media"></div>
            <div class="kc-pcard__body">
              <h3 class="kc-pcard__name">Book wallet</h3>
              <div class="kc-pcard__price"><span>$—</span></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if has_coll and section.settings.show_view_all -%}
      <div class="kc-grid__footer">
        <a class="kc-btn kc-btn--outline" href="{{ coll.url }}">
          {{ section.settings.view_all_text | default: 'View all' }}
          <span class="kc-btn__arrow">→</span>
        </a>
      </div>
    {%- elsif has_coll == false -%}
      <div class="kc-grid__empty">
        Pick a collection in this section's settings to show products.
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .kc-grid-section { padding: 60px 0; background: var(--kc-paper); }
  .kc-grid__header { text-align: center; margin-bottom: 40px; }
  .kc-grid__eyebrow {
    display: inline-block;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--kc-tan, #C47B47);
    margin-bottom: 12px;
  }
  .kc-grid__title {
    font-family: var(--kc-font-serif, 'Fraunces', serif);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 400;
    color: var(--kc-navy, #1A3553);
    margin: 0;
    line-height: 1.1;
  }
  .kc-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols-mobile, 2), 1fr);
    gap: 24px 16px;
  }
  @media (min-width: 768px) {
    .kc-grid { grid-template-columns: repeat(var(--cols, 4), 1fr); gap: 40px 24px; }
  }
  .kc-pcard {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
  }
  .kc-pcard:hover { transform: translateY(-4px); }
  .kc-pcard--placeholder { pointer-events: none; }
  .kc-pcard__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--kc-cream, #F5EDE0);
    border-radius: 4px;
    overflow: hidden;
  }
  .kc-pcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .kc-pcard:hover .kc-pcard__media img { transform: scale(1.04); }
  .kc-pcard__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 10px;
    background: var(--kc-navy, #1A3553);
    color: #fff;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
  }
  .kc-pcard__badge--sale { background: var(--kc-tan, #C47B47); }
  .kc-pcard__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 2px;
  }
  .kc-pcard__name {
    font-family: var(--kc-font-serif, 'Fraunces', serif);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--kc-navy, #1A3553);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .kc-pcard__name { font-size: 16px; }
  }
  .kc-pcard__price {
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 14px;
    color: var(--kc-navy, #1A3553);
    display: flex;
    gap: 8px;
    align-items: baseline;
  }
  .kc-pcard__price-sale { color: var(--kc-tan, #C47B47); font-weight: 500; }
  .kc-pcard__price-compare { color: var(--kc-muted, #8a8786); text-decoration: line-through; font-size: 13px; }
  .kc-grid__footer { text-align: center; margin-top: 48px; }
  .kc-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 14px;
    letter-spacing: 0.05em;
    text-decoration: none;
    border-radius: 2px;
    transition: all 0.3s ease;
  }
  .kc-btn--outline {
    background: transparent;
    border: 1px solid var(--kc-navy, #1A3553);
    color: var(--kc-navy, #1A3553);
  }
  .kc-btn--outline:hover {
    background: var(--kc-navy, #1A3553);
    color: #fff;
  }
  .kc-btn__arrow { transition: transform 0.3s ease; }
  .kc-btn:hover .kc-btn__arrow { transform: translateX(4px); }
  .kc-grid__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 20px;
    color: var(--kc-muted, #8a8786);
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 13px;
  }
</style>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow text",
      "default": "The collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our book wallets"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products to show",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "View all button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Button text",
      "default": "View all"
    }
  ],
  "presets": [
    { "name": "Product grid" }
  ]
}
{% endschema %}