{%- liquid
  assign cols = section.settings.columns | default: 4
  assign cols_m = section.settings.columns_mobile | default: 2
  assign lim = section.settings.limit | default: 8
  assign coll_handle = section.settings.collection
  assign has_coll = false
  assign coll_link = '/collections/all'
  if coll_handle != blank
    assign coll = collections[coll_handle]
    if coll != blank and coll.products_count > 0
      assign has_coll = true
      assign coll_link = coll.url
    endif
  endif
-%}

<section class="kc-grid-section">
  <div class="kc-wrap">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="kc-grid__header">
        {%- if section.settings.subheading != blank -%}
          <span class="kc-grid__eyebrow">{{ section.settings.subheading }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="kc-grid__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="kc-grid" style="--cols: {{ cols }}; --cols-mobile: {{ cols_m }};">
      {%- if has_coll -%}
        {%- for product in coll.products limit: lim -%}
          <a class="kc-pcard" href="{{ product.url }}">
            <div class="kc-pcard__media">
              {%- if product.featured_image != blank -%}
                <img src="{{ product.featured_image | image_url: width: 800 }}"
                     alt="{{ product.featured_image.alt | default: product.title | escape }}"
                     loading="lazy"
                     width="800" height="800">
              {%- endif -%}
              {%- if product.available == false -%}
                <span class="kc-pcard__badge">Sold out</span>
              {%- elsif product.compare_at_price > product.price -%}
                <span class="kc-pcard__badge kc-pcard__badge--sale">Sale</span>
              {%- endif -%}
            </div>
            <div class="kc-pcard__body">
              <h3 class="kc-pcard__name">{{ product.title }}</h3>
              <div class="kc-pcard__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="kc-pcard__price-sale">{{ product.price | money }}</span>
                  <span class="kc-pcard__price-compare">{{ product.compare_at_price | money }}</span>
                {%- else -%}
                  <span>{{ product.price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="kc-pcard kc-pcard--placeholder">
            <div class="kc-pcard__media"></div>
            <div class="kc-pcard__body">
              <h3 class="kc-pcard__name">Book wallet</h3>
              <div class="kc-pcard__price"><span>$—</span></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if has_coll and section.settings.show_view_all -%}
      <div class="kc-grid__footer">
        <a class="kc-btn kc-btn--outline" href="{{ coll_link }}">
          {{ section.settings.view_all_text | default: 'View all' }}
          <span class="kc-btn__arrow">→</span>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
.kc-collection__pagination {
    margin-top: 60px;
    text-align: center;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 14px;
  }
  .kc-collection__pagination a,
  .kc-collection__pagination span {
    display: inline-block;
    padding: 8px 14px;
    margin: 0 2px;
    color: var(--kc-navy, #1A3553);
    text-decoration: none;
    border-radius: 2px;
  }
  .kc-collection__pagination a:hover {
    background: var(--kc-cream, #F5EDE0);
  }
  .kc-collection__pagination .page.current {
    background: var(--kc-navy, #1A3553);
    color: #fff;
    font-weight: 500;
  }
  .kc-collection__pagination a:hover {
    border-color: var(--kc-navy, #1A3553);
  }
  .kc-collection__pagination .page.current,
  .kc-collection__pagination span.page.current {
    background: var(--kc-navy, #1A3553);
    color: #fff;
    border-color: var(--kc-navy, #1A3553);
    font-weight: 500;
  }
  .kc-collection__pagination .prev,
  .kc-collection__pagination .next,
  .kc-collection__pagination .deprecated {
    font-size: 13px;
    letter-spacing: 0.02em;
  }
  .kc-collection__pagination .deprecated {
    color: var(--kc-muted, #8a8786);
    cursor: default;
  }
  @media (max-width: 600px) {
    .kc-collection__pagination { gap: 4px; font-size: 13px; }
    .kc-collection__pagination > * { min-width: 36px; height: 36px; padding: 0 8px; }
  }


  /* Force badge back onto image */
  .kc-pcard__media {
    position: relative !important;
  }
  .kc-pcard__badge {
    position: absolute !important;
    top: 10px !important;
    left: 10px !important;
    display: inline-block !important;
    padding: 3px 8px !important;
    font-size: 10px !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    z-index: 2 !important;
  }
  /* Tighten mobile spacing */
  @media (max-width: 600px) {
    .kc-pcard { gap: 8px; }
    .kc-pcard__name { font-size: 14px !important; line-height: 1.25 !important; }
    .kc-pcard__price { font-size: 13px; gap: 6px; }
  }

  
</style>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "subheading", "label": "Eyebrow text", "default": "The collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our book wallets" },
    { "type": "header", "content": "Products" },
    { "type": "collection", "id": "collection", "label": "Collection to display" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 4, "max": 24, "step": 2, "default": 8 },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "columns", "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ], "default": "4" },
    { "type": "select", "id": "columns_mobile", "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ], "default": "2" },
    { "type": "header", "content": "View all button" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show View all button", "default": true },
    { "type": "text", "id": "view_all_text", "label": "Button text", "default": "View all" }
  ],
  "presets": [ { "name": "Product grid" } ]
}
{% endschema %}