<footer class="kc-footer" role="contentinfo">
  <div class="kc-footer__inner">
    {%- if section.settings.newsletter_enabled -%}
      <div class="kc-footer__col kc-footer__col--newsletter">
        {%- if section.settings.newsletter_heading != blank -%}
          <h4>{{ section.settings.newsletter_heading }}</h4>
        {%- endif -%}
        {%- if section.settings.newsletter_text != blank -%}
          <p class="kc-footer__tag">{{ section.settings.newsletter_text }}</p>
        {%- endif -%}
        <form class="kc-footer__newsletter" action="/contact#contact_form" method="post" id="ContactFooter">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label>
            <span class="visually-hidden">Email</span>
            <input type="email" name="contact[email]" placeholder="Enter your email" required>
          </label>
          <button type="submit">Subscribe →</button>
        </form>
      </div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- if block.type == 'links' -%}
        <div class="kc-footer__col" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.heading }}</h4>
          <ul>
            {%- if block.settings.menu != blank -%}
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="kc-footer__bottom">
    <div class="kc-footer__legal">
      <span>© {{ 'now' | date: "%Y" }} {{ shop.name }}</span>
      {%- if section.settings.show_policies -%}
        <span class="kc-footer__divider">·</span>
        {%- if shop.privacy_policy != blank -%}
          <a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title }}</a>
        {%- endif -%}
        {%- if shop.terms_of_service != blank -%}
          <a href="{{ shop.terms_of_service.url }}">{{ shop.terms_of_service.title }}</a>
        {%- endif -%}
        {%- if shop.shipping_policy != blank -%}
          <a href="{{ shop.shipping_policy.url }}">{{ shop.shipping_policy.title }}</a>
        {%- endif -%}
        {%- if shop.refund_policy != blank -%}
          <a href="{{ shop.refund_policy.url }}">{{ shop.refund_policy.title }}</a>
        {%- endif -%}
        {%- if shop.contact_information != blank -%}
          <a href="/pages/contact">Contact</a>
        {%- endif -%}
      {%- endif -%}
    </div>
    <div class="kc-footer__social">
      {%- if settings.social_instagram != blank -%}
        <a href="{{ settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      {%- endif -%}
      {%- if settings.social_tiktok != blank -%}
        <a href="{{ settings.social_tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19.321 5.562a5.124 5.124 0 01-.443-.258 6.228 6.228 0 01-1.137-.966c-.849-.971-1.165-1.956-1.282-2.645h.004C16.368 1.175 16.4 1 16.4 1h-3.359v12.975c0 .174 0 .347-.007.517l-.001.064-.003.028v.013a2.848 2.848 0 01-1.431 2.262 2.8 2.8 0 01-1.387.367 2.829 2.829 0 110-5.655c.313 0 .615.052.896.146l.004-3.419a6.205 6.205 0 00-.915-.068 6.198 6.198 0 00-4.657 2.089 6.135 6.135 0 00-1.517 3.977c-.007.247-.007.494.002.737a6.192 6.192 0 001.514 3.779 6.198 6.198 0 004.658 2.09 6.15 6.15 0 00.914-.068 6.188 6.188 0 003.744-1.976 6.133 6.133 0 001.591-4.174l-.016-6.696a8.44 8.44 0 001.929 1.103 8.494 8.494 0 002.982.576V5.762a5.175 5.175 0 01-1.021-.2z"/></svg>
        </a>
      {%- endif -%}
      {%- if settings.social_facebook != blank -%}
        <a href="{{ settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      {%- endif -%}
      {%- if settings.social_pinterest != blank -%}
        <a href="{{ settings.social_pinterest }}" aria-label="Pinterest" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</footer>

<style>
  .kc-footer__legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 16px;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 12px;
    color: var(--kc-muted, #8a8786);
    letter-spacing: 0.02em;
  }
  .kc-footer__legal a {
    color: var(--kc-muted, #8a8786);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .kc-footer__legal a:hover {
    color: var(--kc-navy, #1A3553);
  }
  .kc-footer__divider {
    opacity: 0.5;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enabled",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Join the list"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter description",
      "default": "First looks at new releases, small-batch drops, and restocks."
    },
    {
      "type": "header",
      "content": "Legal"
    },
    {
      "type": "checkbox",
      "id": "show_policies",
      "label": "Show policy links in footer",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "Policy links (Privacy, Terms, Shipping, Returns) auto-pull from your Shopify policy pages. Edit those in Settings → Policies."
    }
  ],
  "blocks": [
    {
      "type": "links",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "links", "settings": { "heading": "Shop" }},
      { "type": "links", "settings": { "heading": "About" }},
      { "type": "links", "settings": { "heading": "Help" }}
    ]
  }
}
{% endschema %}

<style>
  .kc-footer {
    background: var(--kc-navy, #1A3553);
    color: #FBFAF7;
    padding: 80px 0 24px;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
  }
  .kc-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px 32px;
  }
  @media (min-width: 768px) {
    .kc-footer__inner {
      padding: 0 40px;
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 48px;
    }
  }

  .kc-footer__col--newsletter { max-width: 380px; }
  .kc-footer__col h4 {
    font-family: var(--kc-font-serif, 'Fraunces', serif);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #FBFAF7;
    margin: 0 0 20px;
  }
  .kc-footer__tag {
    font-size: 14px;
    line-height: 1.6;
    opacity: 0.7;
    margin: 0 0 20px;
  }

  .kc-footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .kc-footer__col a {
    color: #FBFAF7;
    text-decoration: none;
    font-size: 14px;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  .kc-footer__col a:hover { opacity: 1; }

  /* Newsletter form */
  .kc-footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 8px;
  }
  .kc-footer__newsletter input[type="email"] {
    background: transparent;
    border: 1px solid rgba(251, 250, 247, 0.25);
    padding: 12px 14px;
    font-family: inherit;
    font-size: 14px;
    color: #FBFAF7;
    border-radius: 2px;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .kc-footer__newsletter input[type="email"]::placeholder {
    color: rgba(251, 250, 247, 0.5);
  }
  .kc-footer__newsletter input[type="email"]:focus {
    border-color: var(--kc-tan, #C47B47);
  }
  .kc-footer__newsletter button {
    background: var(--kc-tan, #C47B47);
    color: #FBFAF7;
    border: none;
    padding: 12px 18px;
    font-family: inherit;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .kc-footer__newsletter button:hover {
    background: #B36A3A;
  }

  /* Bottom bar */
  .kc-footer__bottom {
    max-width: 1280px;
    margin: 64px auto 0;
    padding: 24px 20px 0;
    border-top: 1px solid rgba(251, 250, 247, 0.12);
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }
  @media (min-width: 768px) {
    .kc-footer__bottom {
      padding: 24px 40px 0;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .kc-footer__legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px 14px;
    font-size: 12px;
    color: rgba(251, 250, 247, 0.6);
    letter-spacing: 0.02em;
  }
  .kc-footer__legal a {
    color: rgba(251, 250, 247, 0.6);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .kc-footer__legal a:hover {
    color: #FBFAF7;
  }
  .kc-footer__divider { opacity: 0.4; }

  /* Social icons */
  .kc-footer__social {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .kc-footer__social a {
    width: 20px;
    height: 20px;
    color: rgba(251, 250, 247, 0.6);
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .kc-footer__social a:hover { color: #FBFAF7; }
  .kc-footer__social svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }



@media (min-width: 768px) {
    .kc-footer__bottom {
      padding: 24px 40px 0;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 20px;
    }
  }


  .kc-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px 32px;
  }
  @media (min-width: 768px) {
    .kc-footer__inner {
      padding: 0 40px;
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 48px;
    }
  }

  .kc-footer__col--newsletter {
    max-width: 560px;
    width: 100%;
    align-items: center;
    text-align: center;
  }
  .kc-footer__col h4 {
    font-family: var(--kc-font-serif, 'Fraunces', serif);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #FBFAF7;
    margin: 0 0 20px;
    text-align: center;
  }
  .kc-footer__tag {
    font-size: 14px;
    line-height: 1.6;
    opacity: 0.7;
    margin: 0 0 24px;
    text-align: center;
    max-width: 480px;
  }


  .kc-footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 8px;
    width: 100%;
    max-width: 480px;
  }
  .kc-footer__newsletter label {
    width: 100%;
    display: block;
  }
  .kc-footer__newsletter input[type="email"] {
    width: 100%;
    padding: 14px 18px;
    font-size: 15px;
  }
  .kc-footer__newsletter button {
    padding: 14px 24px;
  }

  
</style>

