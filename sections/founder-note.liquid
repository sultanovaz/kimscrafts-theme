<section class="kc-founder">
  <div class="kc-founder__inner">
    <div class="kc-founder__media kc-reveal">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
    <div class="kc-founder__text kc-reveal" data-delay="1">
      {%- if section.settings.eyebrow != blank -%}
        <div class="kc-eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="kc-founder__title">{{ section.settings.heading }}</h2>
      <div class="kc-founder__body">{{ section.settings.body }}</div>
      {%- if section.settings.signature != blank -%}
        <div class="kc-founder__sig">{{ section.settings.signature }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Founder note",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Made by hand"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>No two are the <em>exactly</em> alike.</p>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Each book wallet is cut, folded and saddle-stitched from a single piece of full-grain leather. Small flaws in the grain, slight shifts in color — those aren't defects. They're the reason we work this way.</p><p>Order today and yours goes on the bench this week.</p>"
    },
    {
      "type": "text",
      "id": "signature",
      "label": "Signature",
      "default": "— Kim"
    }
  ],
  "presets": [
    { "name": "Founder note" }
  ]
}
{% endschema %}
