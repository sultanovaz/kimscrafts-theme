<header class="kc-header" role="banner">
  <div class="kc-header__inner">

    {%- comment -%} Nav / menu button {%- endcomment -%}
    <div class="kc-header__nav" role="navigation" aria-label="Main">
      {%- if section.settings.menu != blank -%}
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/collections/all">Shop</a>
        <a href="/pages/our-story">Our Story</a>
        <a href="/pages/care">Care</a>
      {%- endif -%}
    </div>

    <button type="button" class="kc-header__icon kc-menu-toggle" data-menu-toggle aria-label="Open menu">
      {%- render 'icon-menu' -%}
    </button>

    {%- comment -%} Logo {%- endcomment -%}
    <a href="/" class="kc-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.custom_logo != blank -%}
        <img
          src="{{ section.settings.custom_logo | image_url: width: 600 }}"
          alt="{{ shop.name }}"
          style="height: {{ section.settings.logo_height | default: 40 }}px; width: auto;"
          loading="eager"
        >
      {%- elsif settings.logo != blank -%}
        <img
          src="{{ settings.logo | image_url: width: 600 }}"
          alt="{{ shop.name }}"
          style="height: {{ section.settings.logo_height | default: 40 }}px; width: auto;"
          loading="eager"
        >
      {%- else -%}
        <span class="kc-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Actions {%- endcomment -%}
    <div class="kc-header__actions">
      <a href="/search" class="kc-header__icon" aria-label="Search">
        {%- render 'icon-search' -%}
      </a>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{% if customer %}/account{% else %}/account/login{% endif %}" class="kc-header__icon" aria-label="Account">
          {%- render 'icon-account' -%}
        </a>
      {%- endif -%}
      <a href="/cart" class="kc-header__icon" aria-label="Cart">
        {%- render 'icon-cart' -%}
        <span class="kc-cart-count" data-cart-count{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

{%- comment -%} Mobile drawer {%- endcomment -%}
<div class="kc-mobile-drawer" data-mobile-drawer aria-hidden="true">
  <button class="kc-header__icon kc-mobile-drawer__close" data-menu-close aria-label="Close menu">
    {%- render 'icon-close' -%}
  </button>
  {%- if section.settings.menu != blank -%}
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {%- endfor -%}
  {%- else -%}
    <a href="/collections/all">Shop</a>
    <a href="/pages/our-story">Our Story</a>
    <a href="/pages/care">Care</a>
  {%- endif -%}
  {%- if shop.customer_accounts_enabled -%}
    <a href="{% if customer %}/account{% else %}/account/login{% endif %}">Account</a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "custom_logo",
      "label": "Logo image",
      "info": "Upload your logo here. PNG with transparent background works best."
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height (px)",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 40
    }
  ]
}
{% endschema %}


<style>
  @media (max-width: 767px) {
    .kc-header__logo img {
      height: 28px !important;
      max-width: 140px;
      object-fit: contain;
    }
    .kc-header {
      padding-top: 8px;
      padding-bottom: 8px;
    }
  }
</style>