<header class="kc-header" role="banner">
  <div class="kc-header__inner">

    {%- comment -%} Nav / menu button {%- endcomment -%}
    <div class="kc-header__nav" role="navigation" aria-label="Main">
      {%- if section.settings.menu != blank -%}
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/collections/all">Shop</a>
        <a href="/pages/our-story">Our Story</a>
        <a href="/pages/care">Care</a>
      {%- endif -%}
    </div>

   <button type="button" class="kc-header__icon kc-menu-toggle" data-menu-toggle aria-label="Open menu">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
    <line x1="3" y1="7" x2="21" y2="7"/>
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="17" x2="21" y2="17"/>
  </svg>
</button>

    {%- comment -%} Logo {%- endcomment -%}
    <a href="/" class="kc-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.custom_logo != blank -%}
        <img
          src="{{ section.settings.custom_logo | image_url: width: 600 }}"
          alt="{{ shop.name }}"
          style="height: {{ section.settings.logo_height | default: 40 }}px; width: auto;"
          loading="eager"
        >
      {%- elsif settings.logo != blank -%}
        <img
          src="{{ settings.logo | image_url: width: 600 }}"
          alt="{{ shop.name }}"
          style="height: {{ section.settings.logo_height | default: 40 }}px; width: auto;"
          loading="eager"
        >
      {%- else -%}
        <span class="kc-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Actions {%- endcomment -%}
    <div class="kc-header__actions">
      <a href="/search" class="kc-header__icon" aria-label="Search">
        {%- render 'icon-search' -%}
      </a>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{% if customer %}/account{% else %}/account/login{% endif %}" class="kc-header__icon" aria-label="Account">
          {%- render 'icon-account' -%}
        </a>
      {%- endif -%}
      <a href="/cart" class="kc-header__icon" aria-label="Cart">
        {%- render 'icon-cart' -%}
        <span class="kc-cart-count" data-cart-count{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

{%- comment -%} Mobile drawer {%- endcomment -%}
<div class="kc-mobile-drawer" data-mobile-drawer aria-hidden="true">
  <button class="kc-header__icon kc-mobile-drawer__close" data-menu-close aria-label="Close menu">
    {%- render 'icon-close' -%}
  </button>
  {%- if section.settings.menu != blank -%}
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {%- endfor -%}
  {%- else -%}
    <a href="/collections/all">Shop</a>
    <a href="/pages/our-story">Our Story</a>
    <a href="/pages/care">Care</a>
  {%- endif -%}
  {%- if shop.customer_accounts_enabled -%}
    <a href="{% if customer %}/account{% else %}/account/login{% endif %}">Account</a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "custom_logo",
      "label": "Logo image",
      "info": "Upload your logo here. PNG with transparent background works best."
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height (px)",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 40
    }
  ]
}
{% endschema %}


<style>
  /* ═══════════════════════════════════════════════════════════
     MOBILE HEADER — Premium, editorial, spacious
     ═══════════════════════════════════════════════════════════ */
  @media (max-width: 767px) {
    .kc-header {
      padding: 14px 16px !important;
      background: var(--kc-paper, #FBFAF7);
      border-bottom: 1px solid rgba(26, 53, 83, 0.08);
    }

    .kc-header__inner {
      display: grid !important;
      grid-template-columns: 1fr auto 1fr !important;
      align-items: center;
      gap: 0;
      position: relative;
      max-width: 100%;
    }

    /* ── LEFT GROUP: hamburger + search ── */
    .kc-header__nav { display: none !important; }

    .kc-menu-toggle {
      grid-column: 1;
      justify-self: start;
      width: 38px;
      height: 38px;
      display: inline-flex !important;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      padding: 0;
      margin: 0;
      color: var(--kc-navy, #1A3553);
      cursor: pointer;
      transition: opacity 0.2s ease;
    }
    .kc-menu-toggle:hover { opacity: 0.6; }
    .kc-menu-toggle svg { width: 20px; height: 20px; }

    /* Pull search icon next to hamburger */
    .kc-header__actions a[href="/search"] {
      position: absolute;
      left: 42px;
      top: 50%;
      transform: translateY(-50%);
      width: 38px;
      height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--kc-navy, #1A3553);
      transition: opacity 0.2s ease;
    }
    .kc-header__actions a[href="/search"]:hover { opacity: 0.6; }
    .kc-header__actions a[href="/search"] svg { width: 18px; height: 18px; }

    /* ── CENTER: logo ── */
    .kc-header__logo {
      grid-column: 2;
      justify-self: center;
      display: block;
      line-height: 0;
      padding: 0 8px;
    }
    .kc-header__logo img {
      height: 36px !important;
      max-width: 180px;
      width: auto;
      object-fit: contain;
      display: block;
    }

    /* ── RIGHT GROUP: account + cart ── */
    .kc-header__actions {
      grid-column: 3;
      justify-self: end;
      display: flex;
      align-items: center;
      gap: 2px;
    }
    .kc-header__actions > a:not([href="/search"]) {
      width: 38px;
      height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--kc-navy, #1A3553);
      position: relative;
      transition: opacity 0.2s ease;
    }
    .kc-header__actions > a:hover { opacity: 0.6; }
    .kc-header__actions svg { width: 18px; height: 18px; }

    /* Cart count badge — premium look */
    .kc-cart-count {
      position: absolute;
      top: 4px;
      right: 2px;
      min-width: 16px;
      height: 16px;
      padding: 0 4px;
      background: var(--kc-tan, #C47B47);
      color: #fff;
      font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
      font-size: 10px;
      font-weight: 500;
      line-height: 16px;
      border-radius: 999px;
      text-align: center;
      letter-spacing: 0;
    }
  }

  /* ═══════════════════════════════════════════════════════════
     DESKTOP HEADER — stays clean
     ═══════════════════════════════════════════════════════════ */
  @media (min-width: 768px) {
    .kc-header__icon svg { width: 18px; height: 18px; }
    .kc-header__actions { gap: 4px; }
  }
</style>

<style>
  /* Force hamburger icon to match others in weight/size */
  .kc-menu-toggle svg {
    width: 16px !important;
    height: 16px !important;
    stroke-width: 1.5 !important;
  }
  .kc-menu-toggle svg line,
  .kc-menu-toggle svg path,
  .kc-menu-toggle svg rect {
    stroke-width: 1.5 !important;
  }

  .kc-header__left {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1 1 0;
  justify-content: flex-start;
}



.kc-header__actions {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1 1 0;
  justify-content: flex-end;
}
</style>


