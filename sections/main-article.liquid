<article class="kc-page">
  <div style="text-align:center; margin-bottom:32px;">
    <div class="kc-eyebrow">{{ article.published_at | date: "%B %d, %Y" }}</div>
    <h1 style="margin-top:12px;">{{ article.title }}</h1>
    {%- if article.author != blank -%}
      <div style="color:var(--kc-muted); font-size:14px; margin-top:8px;">By {{ article.author }}</div>
    {%- endif -%}
  </div>
  {%- if article.image != blank -%}
    <div style="border-radius:var(--kc-r-md); overflow:hidden; margin:0 -20px 48px; aspect-ratio:16/9;">
      <img src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.image.alt | escape }}" style="width:100%; height:100%; object-fit:cover;">
    </div>
  {%- endif -%}
  <div class="rte">{{ article.content }}</div>

  {%- if blog.comments_enabled? -%}
    <div style="margin-top:64px; padding-top:32px; border-top:1px solid var(--kc-line);">
      {%- if article.comments.size > 0 -%}
        <h2 style="font-size:28px; margin-bottom:24px;">{{ article.comments_count }} {{ article.comments_count | pluralize: 'comment', 'comments' }}</h2>
        {%- for comment in article.comments -%}
          <div style="padding:20px 0; border-bottom:1px solid var(--kc-line);">
            <div style="font-weight:500; margin-bottom:6px;">{{ comment.author }}</div>
            <div style="font-size:12px; color:var(--kc-muted); margin-bottom:10px;">{{ comment.created_at | date: "%B %d, %Y" }}</div>
            <div>{{ comment.content }}</div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  {%- endif -%}
</article>

{% schema %}
{ "name": "Article" }
{% endschema %}
