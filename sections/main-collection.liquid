{%- liquid
  assign cols = section.settings.columns | default: 4
  assign cols_m = section.settings.columns_mobile | default: 2
  assign per_page = section.settings.per_page | default: 24
-%}

{%- paginate collection.products by per_page -%}
<section class="kc-collection">
  <div class="kc-wrap">

    <div class="kc-collection__header">
      <span class="kc-collection__eyebrow">Collection</span>
      <h1 class="kc-collection__title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="kc-collection__desc">{{ collection.description }}</div>
      {%- endif -%}
      <div class="kc-collection__count">{{ collection.products_count }} {% if collection.products_count == 1 %}product{% else %}products{% endif %}</div>
    </div>

    <div class="kc-grid" style="--cols: {{ cols }}; --cols-mobile: {{ cols_m }};">
      {%- for product in collection.products -%}
        <a class="kc-pcard" href="{{ product.url }}">
          <div class="kc-pcard__media">
            {%- if product.featured_image != blank -%}
              <img src="{{ product.featured_image | image_url: width: 800 }}"
                   alt="{{ product.featured_image.alt | default: product.title | escape }}"
                   loading="lazy"
                   width="800" height="800">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            {%- if product.available == false -%}
              <span class="kc-pcard__badge">Sold out</span>
            {%- elsif product.compare_at_price > product.price -%}
              <span class="kc-pcard__badge kc-pcard__badge--sale">Sale</span>
            {%- endif -%}
          </div>
          <div class="kc-pcard__body">
            <h3 class="kc-pcard__name">{{ product.title }}</h3>
            <div class="kc-pcard__price">
              {%- if product.compare_at_price > product.price -%}
                <span class="kc-pcard__price-sale">{{ product.price | money }}</span>
                <span class="kc-pcard__price-compare">{{ product.compare_at_price | money }}</span>
              {%- else -%}
                <span>{{ product.price | money }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- else -%}
        <p class="kc-collection__empty">No products yet.</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="kc-collection__pagination">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}

  </div>
</section>
{%- endpaginate -%}

<style>
  .kc-collection { padding: 60px 0; background: var(--kc-paper); overflow: hidden; box-sizing: border-box; }
  .kc-collection * { box-sizing: border-box; }
  .kc-collection .kc-wrap { max-width: 1280px; margin: 0 auto; padding: 0 20px; }
  @media (min-width: 768px) { .kc-collection .kc-wrap { padding: 0 32px; } }
  .kc-collection__header { text-align: center; margin-bottom: 50px; }
  .kc-collection__eyebrow {
    display: inline-block;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--kc-tan, #C47B47);
    margin-bottom: 12px;
  }
  .kc-collection__title {
    font-family: var(--kc-font-serif, 'Fraunces', serif);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 400;
    color: var(--kc-navy, #1A3553);
    margin: 0 0 16px;
    line-height: 1.1;
  }
  .kc-collection__desc {
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    color: var(--kc-navy, #1A3553);
    max-width: 600px;
    margin: 0 auto 12px;
    line-height: 1.5;
  }
  .kc-collection__count {
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--kc-muted, #8a8786);
  }
  .kc-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols-mobile, 2), minmax(0, 1fr));
    gap: 24px 12px;
  }
  @media (min-width: 768px) {
    .kc-grid { grid-template-columns: repeat(var(--cols, 4), minmax(0, 1fr)); gap: 40px 24px; }
  }
  .kc-pcard {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
    min-width: 0;
  }
  .kc-pcard:hover { transform: translateY(-4px); }
  .kc-pcard__media {
    position: relative;
    aspect-ratio: 1/1;
    background: var(--kc-cream, #F5EDE0);
    border-radius: 4px;
    overflow: hidden;
    width: 100%;
  }
  .kc-pcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .kc-pcard:hover .kc-pcard__media img { transform: scale(1.04); }
  .kc-pcard__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 10px;
    background: var(--kc-navy, #1A3553);
    color: #fff;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
  }
  .kc-pcard__badge--sale { background: var(--kc-tan, #C47B47); }
  .kc-pcard__body { display: flex; flex-direction: column; gap: 4px; padding: 0 2px; min-width: 0; }
  .kc-pcard__name {
    font-family: var(--kc-font-serif, 'Fraunces', serif);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--kc-navy, #1A3553);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    word-break: break-word;
  }
  @media (min-width: 768px) { .kc-pcard__name { font-size: 16px; } }
  .kc-pcard__price {
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 14px;
    color: var(--kc-navy, #1A3553);
    display: flex;
    gap: 8px;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .kc-pcard__price-sale { color: var(--kc-tan, #C47B47); font-weight: 500; }
  .kc-pcard__price-compare { color: var(--kc-muted, #8a8786); text-decoration: line-through; font-size: 13px; }
  .kc-collection__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    color: var(--kc-muted, #8a8786);
  }
  .kc-collection__pagination {
    margin-top: 60px;
    text-align: center;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
  }
  .kc-collection__pagination a,
  .kc-collection__pagination span {
    display: inline-block;
    padding: 8px 14px;
    margin: 0 2px;
    color: var(--kc-navy, #1A3553);
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: 2px;
    transition: all 0.2s ease;
  }
  .kc-collection__pagination a:hover { border-color: var(--kc-navy, #1A3553); }
  .kc-collection__pagination .page.current {
    border-color: var(--kc-navy, #1A3553);
    background: var(--kc-navy, #1A3553);
    color: #fff;
  }
</style>

{% schema %}
{
  "name": "Collection page",
  "settings": [
    {
      "type": "range",
      "id": "per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    }
  ]
}
{% endschema %}