{%- liquid
  assign cols = section.settings.columns | default: 4
  assign cols_m = section.settings.columns_mobile | default: 2
  assign per_page = section.settings.per_page | default: 24
-%}

{%- paginate collection.products by per_page -%}
<section class="kc-collection">
  <div class="kc-wrap">

    <div class="kc-collection__header">
      <span class="kc-collection__eyebrow">Collection</span>
      <h1 class="kc-collection__title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="kc-collection__desc">{{ collection.description }}</div>
      {%- endif -%}
      <div class="kc-collection__count">{{ collection.products_count }} {% if collection.products_count == 1 %}product{% else %}products{% endif %}</div>
    </div>

    <div class="kc-grid" style="--cols: {{ cols }}; --cols-mobile: {{ cols_m }};">
      {%- for product in collection.products -%}
        <a class="kc-pcard" href="{{ product.url }}">
          <div class="kc-pcard__media">
            {%- if product.featured_image != blank -%}
              <img src="{{ product.featured_image | image_url: width: 800 }}"
                   alt="{{ product.featured_image.alt | default: product.title | escape }}"
                   loading="lazy"
                   width="800" height="800">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            {%- if product.available == false -%}
              <span class="kc-pcard__badge">Sold out</span>
            {%- elsif product.compare_at_price > product.price -%}
              <span class="kc-pcard__badge kc-pcard__badge--sale">Sale</span>
            {%- endif -%}
          </div>
          <div class="kc-pcard__body">
            <h3 class="kc-pcard__name">{{ product.title }}</h3>
            <div class="kc-pcard__price">
              {%- if product.compare_at_price > product.price -%}
                <span class="kc-pcard__price-sale">{{ product.price | money }}</span>
                <span class="kc-pcard__price-compare">{{ product.compare_at_price | money }}</span>
              {%- else -%}
                <span>{{ product.price | money }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- else -%}
        <p class="kc-collection__empty">No products yet.</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="kc-collection__pagination">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}

  </div>
</section>
{%- endpaginate -%}

<style>
.kc-collection__pagination {
    margin-top: 60px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    font-family: var(--kc-font-sans, 'DM Sans', sans-serif);
    font-size: 14px;
  }
  .kc-collection__pagination > * {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    margin: 0 !important;
    color: var(--kc-navy, #1A3553);
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: 2px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .kc-collection__pagination a:hover {
    border-color: var(--kc-navy, #1A3553);
  }
  .kc-collection__pagination .page.current,
  .kc-collection__pagination span.page.current {
    background: var(--kc-navy, #1A3553);
    color: #fff;
    border-color: var(--kc-navy, #1A3553);
    font-weight: 500;
  }
  .kc-collection__pagination .prev,
  .kc-collection__pagination .next,
  .kc-collection__pagination .deprecated {
    font-size: 13px;
    letter-spacing: 0.02em;
  }
  .kc-collection__pagination .deprecated {
    color: var(--kc-muted, #8a8786);
    cursor: default;
  }
  @media (max-width: 600px) {
    .kc-collection__pagination { gap: 4px; font-size: 13px; }
    .kc-collection__pagination > * { min-width: 36px; height: 36px; padding: 0 8px; }
  }
</style>

{% schema %}
{
  "name": "Collection page",
  "settings": [
    {
      "type": "range",
      "id": "per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    }
  ]
}
{% endschema %}