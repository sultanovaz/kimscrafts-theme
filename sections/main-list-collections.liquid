<section class="kc-collection">
  <div class="kc-wrap">
    <header class="kc-collection__head">
      <div class="kc-eyebrow">Collections</div>
      <h1 class="kc-collection__title">All collections</h1>
    </header>

    <div class="kc-grid" style="--cols: 3; --cols-mobile: 2;">
      {%- for coll in collections -%}
        {%- unless coll.handle == 'frontpage' -%}
          <a class="kc-card kc-reveal" data-delay="{{ forloop.index0 | modulo: 4 }}" href="{{ coll.url }}">
            <div class="kc-card__frame">
              {%- if coll.image != blank -%}
                <img class="kc-card__img" src="{{ coll.image | image_url: width: 800 }}" alt="{{ coll.image.alt | escape }}" loading="lazy">
              {%- elsif coll.products.first.featured_image != blank -%}
                <img class="kc-card__img" src="{{ coll.products.first.featured_image | image_url: width: 800 }}" alt="" loading="lazy">
              {%- endif -%}
              <div class="kc-card__reveal"><span>View collection</span><span class="arrow">→</span></div>
            </div>
            <div class="kc-card__info">
              <div class="kc-card__name">{{ coll.title }}</div>
              <div class="kc-card__price">{{ coll.products_count }} items</div>
            </div>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "List collections" }
{% endschema %}
