<section class="kc-page">
  <div class="kc-wrap--narrow">

    <header class="kc-page__head kc-reveal">
      <div class="kc-eyebrow">Page</div>
      <h1 class="kc-page__title">{{ page.title }}</h1>
    </header>

    <div class="kc-page__content kc-reveal" data-delay="1">
      {{ page.content }}
    </div>

    {%- if page.template_suffix == 'contact' or page.handle contains 'contact' -%}
      <div class="kc-contact-form kc-reveal" data-delay="2">

        {%- form 'contact', class: 'kc-form' -%}

          {%- if form.posted_successfully? -%}
            <div class="kc-form__success">
              <strong>Thank you —</strong> your message has been received. We'll reply within 1-2 business days.
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="kc-form__errors">
              <strong>Please fix the following:</strong>
              <ul>
                {%- for field in form.errors -%}
                  <li>{{ form.errors.messages[field] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <div class="kc-form__row">
            <label for="contact-name" class="kc-form__label">Name</label>
            <input type="text" id="contact-name" name="contact[name]" class="kc-form__input" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" required>
          </div>

          <div class="kc-form__row">
            <label for="contact-email" class="kc-form__label">Email</label>
            <input type="email" id="contact-email" name="contact[email]" class="kc-form__input" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" autocorrect="off" autocapitalize="off" required>
          </div>

          <div class="kc-form__row">
            <label for="contact-order" class="kc-form__label">Order number (optional)</label>
            <input type="text" id="contact-order" name="contact[order_number]" class="kc-form__input" placeholder="e.g. #1234">
          </div>

          <div class="kc-form__row">
            <label for="contact-message" class="kc-form__label">How can we help?</label>
            <textarea id="contact-message" name="contact[body]" class="kc-form__textarea" rows="6" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>

          <button type="submit" class="kc-btn kc-btn--primary kc-btn--full">Send message</button>

          <p class="kc-form__note">We reply to every email within 1–2 business days at support@kimscrafts.co.</p>

        {%- endform -%}

      </div>
    {%- endif -%}

  </div>
</section>

<style>
.kc-contact-form {
  margin-top: 48px;
  padding-top: 48px;
  border-top: 1px solid var(--kc-line, #E8E0D0);
}
.kc-form__row {
  margin-bottom: 20px;
}
.kc-form__label {
  display: block;
  font-family: var(--kc-f-body, 'DM Sans', sans-serif);
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--kc-tan, #C47B47);
  margin-bottom: 8px;
  font-weight: 500;
}
.kc-form__input,
.kc-form__textarea {
  width: 100%;
  padding: 14px 16px;
  font-family: var(--kc-f-body, 'DM Sans', sans-serif);
  font-size: 15px;
  color: var(--kc-ink, #141414);
  background: var(--kc-paper, #FBFAF7);
  border: 1px solid var(--kc-line-dark, #D8CFB8);
  border-radius: 2px;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}
.kc-form__input:focus,
.kc-form__textarea:focus {
  outline: none;
  border-color: var(--kc-navy, #1A3553);
}
.kc-form__textarea {
  resize: vertical;
  min-height: 140px;
  font-family: var(--kc-f-body, 'DM Sans', sans-serif);
}
.kc-form__success {
  background: #F0F7E8;
  border: 1px solid #C4D9A0;
  color: #3F5F15;
  padding: 16px 20px;
  margin-bottom: 24px;
  border-radius: 2px;
  font-size: 14px;
}
.kc-form__errors {
  background: #FBE8E0;
  border: 1px solid #E5A584;
  color: #8C3A1C;
  padding: 16px 20px;
  margin-bottom: 24px;
  border-radius: 2px;
  font-size: 14px;
}
.kc-form__errors ul {
  margin: 8px 0 0 20px;
  padding: 0;
}
.kc-form__note {
  margin-top: 16px;
  font-size: 12px;
  color: var(--kc-muted, #6B6458);
  text-align: center;
}

