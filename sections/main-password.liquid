<section class="kc-password-page">
  <h1>{{ shop.name }}</h1>
  {%- if shop.password_message != blank -%}
    <p style="max-width:460px; margin:0 auto; color:var(--kc-ink-soft); line-height:1.7;">{{ shop.password_message }}</p>
  {%- else -%}
    <p style="max-width:460px; margin:0 auto; color:var(--kc-ink-soft); line-height:1.7;">Opening soon. Leave your email to be the first to know.</p>
  {%- endif -%}

  <div style="margin-top:32px; max-width:400px; width:100%;">
    {%- form 'customer', id: 'ContactFooter', class: 'kc-footer__newsletter' -%}
      <input type="hidden" name="contact[tags]" value="prospect,newsletter">
      {%- if form.posted_successfully? -%}
        <p class="kc-notif kc-notif--success" style="text-align:center;">{{ 'newsletter.success' | t }}</p>
      {%- else -%}
        <div style="display:flex; gap:8px;">
          <input type="email" name="contact[email]" placeholder="you@email.com" required
                 style="flex:1; padding:14px 18px; border:1px solid var(--kc-line-dark); background:var(--kc-paper); border-radius:2px;">
          <button type="submit" class="kc-btn kc-btn--primary">Notify me</button>
        </div>
      {%- endif -%}
    {%- endform -%}
  </div>

  <div style="margin-top:48px;">
    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p class="kc-notif kc-notif--error" style="margin-bottom:16px;">{{ 'general.password_page.login_form_error' | t }}</p>
      {%- endif -%}
      <details style="cursor:pointer; color:var(--kc-muted); font-size:13px;">
        <summary>{{ 'general.password_page.login_form_heading' | t }}</summary>
        <div style="display:flex; gap:8px; margin-top:16px; max-width:400px;">
          <input type="password" name="password" placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
                 style="flex:1; padding:14px 18px; border:1px solid var(--kc-line-dark); background:var(--kc-paper); border-radius:2px;">
          <button type="submit" class="kc-btn kc-btn--secondary">{{ 'general.password_page.login_form_submit' | t }}</button>
        </div>
      </details>
    {%- endform -%}
  </div>
</section>

{% schema %}
{ "name": "Password" }
{% endschema %}
