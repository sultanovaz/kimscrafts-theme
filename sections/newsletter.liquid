<section class="kc-newsletter" style="background: {{ section.settings.bg_color | default: 'var(--kc-cream)' }};">
  <div class="kc-wrap--narrow">
    <div class="kc-newsletter__inner kc-reveal">
      {%- if section.settings.eyebrow != blank -%}<div class="kc-eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="kc-newsletter__title">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.subtext != blank -%}<p class="kc-newsletter__sub">{{ section.settings.subtext }}</p>{%- endif -%}

      {%- form 'customer', id: 'NewsletterForm', class: 'kc-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p class="kc-newsletter__success">Thank you — check your inbox for a welcome note.</p>
        {%- else -%}
          <div class="kc-newsletter__row">
            <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder | default: 'you@email.com' }}" required>
            <button type="submit" class="kc-btn kc-btn--primary">{{ section.settings.button_label | default: 'Subscribe' }}</button>
          </div>
          {%- if section.settings.disclaimer != blank -%}
            <p class="kc-newsletter__disclaimer">{{ section.settings.disclaimer }}</p>
          {%- endif -%}
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The list" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Restocks, <em>early access</em>, small stories.</p>" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "One or two emails a month. Never pushy, never daily." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "you@email.com" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "By subscribing you agree to our privacy policy. Unsubscribe any time." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
