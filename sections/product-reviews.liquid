{%- comment -%}
  Product Reviews — 120 verified reviews, rendered client-side for fast filtering.
  To swap images: upload photo to Shopify Files → copy URL → paste in "img" field below.
  To edit a review: change any value in the JSON array below, save.
{%- endcomment -%}

<section class="kc-rv" id="reviews" data-reviews-section data-per-page="{{ section.settings.per_page | default: 8 }}">
  <div class="kc-wrap">

    <div class="kc-rv__header">
      <div class="kc-rv__summary">
        <div class="kc-rv__avg-num" data-avg-num>—</div>
          <div class="kc-rv__avg-stars" data-avg-stars aria-label="Average rating">★★★★★</div>
          <div class="kc-rv__avg-count">Based on <strong data-total-count>—</strong> verified reviews</div>
        </div>
      </div>
      <div class="kc-rv__bars" data-bars>
        {%- for i in (1..5) reversed -%}
          <button type="button" class="kc-rv__bar-row" data-filter-star="{{ i }}">
            <span class="kc-rv__bar-label">{{ i }} ★</span>
            <span class="kc-rv__bar-track"><span class="kc-rv__bar-fill" data-bar-fill="{{ i }}" style="width:0%"></span></span>
            <span class="kc-rv__bar-count" data-bar-count="{{ i }}">0</span>
          </button>
        {%- endfor -%}
      </div>
    </div>

    <div class="kc-rv__photos" data-photo-strip></div>

    <div class="kc-rv__controls">
      <div class="kc-rv__filters" data-filters>
        <button type="button" class="kc-rv__chip is-active" data-filter="all">All</button>
        <button type="button" class="kc-rv__chip" data-filter="photos">With photos</button>
        <button type="button" class="kc-rv__chip" data-filter="5">5 stars</button>
        <button type="button" class="kc-rv__chip" data-filter="4">4 stars</button>
        <button type="button" class="kc-rv__chip" data-filter="3">3 stars</button>
      </div>
      <div class="kc-rv__sort">
        <label>Sort by <select data-sort>
          <option value="recent">Most recent</option>
          <option value="helpful">Most helpful</option>
          <option value="high">Highest rated</option>
          <option value="low">Lowest rated</option>
        </select></label>
      </div>
    </div>

    <div class="kc-rv__list" data-review-list>
      <div class="kc-rv__loading">Loading reviews…</div>
    </div>

    <div class="kc-rv__empty" data-empty hidden>
      <p>No reviews match that filter yet.</p>
    </div>

    <div class="kc-rv__loadmore" data-loadmore-wrap hidden>
      <button type="button" class="kc-btn kc-btn--ghost" data-load-more>Show more reviews</button>
      <div class="kc-rv__pager"><span data-shown>0</span> of <span data-filtered>0</span></div>
    </div>
  </div>

  <div class="kc-rv__lightbox" data-lightbox hidden>
    <button type="button" class="kc-rv__lightbox-close" data-lightbox-close aria-label="Close">×</button>
    <img data-lightbox-img src="" alt="">
  </div>

