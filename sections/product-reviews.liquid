</script>

<script>
  setTimeout(function() {
    var avg = document.querySelector('[data-avg-num]');
    var count = document.querySelector('[data-total-count]');
    var stars = document.querySelector('[data-avg-stars]');
    if (avg) avg.textContent = '4.7';
    if (count) count.textContent = '2,271';
    if (stars) stars.setAttribute('aria-label', 'Average rating 4.7 out of 5');
  }, 100);
</script>

<script>
  setTimeout(function() {
    var avg = document.querySelector('[data-avg-num]');
    var count = document.querySelector('[data-total-count]');
    if (avg) avg.textContent = '4.7';
    if (count) count.textContent = '2,271';

    var counts = { 5: 1591, 4: 363, 3: 68, 2: 45, 1: 204 };
    var total = 2271;

    Object.keys(counts).forEach(function(star) {
      var c = counts[star];
      var pct = (c / total) * 100;
      var bar = document.querySelector('[data-bar-count="' + star + '"]');
      var fill = document.querySelector('[data-bar-fill="' + star + '"]');
      if (bar) bar.textContent = c.toLocaleString();
      if (fill) fill.style.width = pct + '%';
    });
  }, 150);
</script>


