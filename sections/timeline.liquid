<section class="kc-timeline">
  <div class="kc-wrap--narrow">
    <div class="kc-timeline__head">
      {%- if section.settings.eyebrow != blank -%}<div class="kc-eyebrow kc-reveal">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="kc-timeline__title kc-reveal" data-delay="1">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    <div class="kc-timeline__track">
      {%- for block in section.blocks -%}
        <div class="kc-timeline__step kc-reveal" data-delay="{{ forloop.index0 | modulo: 4 }}" {{ block.shopify_attributes }}>
          <div class="kc-timeline__marker">
            <span class="kc-timeline__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          </div>
          <div class="kc-timeline__content">
            <h3>{{ block.settings.title }}</h3>
            <div class="kc-timeline__body">{{ block.settings.body }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Timeline / story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How it's made" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Four hands. Four <em>hours.</em></p>" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Cut" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>A single full-grain hide, cut to pattern with a rolling blade and a steady hand.</p>" }
      ]
    }
  ],
  "presets": [{
    "name": "Timeline / story",
    "blocks": [
      { "type": "step", "settings": { "title": "Cut", "body": "<p>A single full-grain hide, cut to pattern with a rolling blade and a steady hand.</p>" }},
      { "type": "step", "settings": { "title": "Skive", "body": "<p>Edges thinned by hand so the fold sits flat and the wallet stays slim.</p>" }},
      { "type": "step", "settings": { "title": "Stitch", "body": "<p>Two needles, waxed linen thread, saddle-stitched one hole at a time.</p>" }},
      { "type": "step", "settings": { "title": "Finish", "body": "<p>Edges burnished, hardware set, and the whole thing packed in a cloth sleeve worth keeping.</p>" }}
    ]
  }]
}
{% endschema %}
