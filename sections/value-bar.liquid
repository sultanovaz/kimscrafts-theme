<section class="kc-values">
  <div class="kc-wrap">
    <div class="kc-values__grid">
      {%- for block in section.blocks -%}
        <div class="kc-value kc-reveal" data-delay="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <div class="kc-value__icon">
            {%- case block.settings.icon -%}
              {%- when 'stitch' -%}
                <svg viewBox="0 0 36 36"><path d="M4 18h28" stroke="currentColor" stroke-width="1.4" stroke-dasharray="3 3" fill="none"/><circle cx="18" cy="18" r="1.5" fill="currentColor"/></svg>
              {%- when 'truck' -%}
                <svg viewBox="0 0 36 36"><path d="M3 8h18v16H3zM21 14h8l3 4v6h-11" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linejoin="round"/><circle cx="9" cy="26" r="2.5" stroke="currentColor" stroke-width="1.4" fill="none"/><circle cx="25" cy="26" r="2.5" stroke="currentColor" stroke-width="1.4" fill="none"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 36 36"><path d="M18 4l12 4v10c0 8-5 13-12 14-7-1-12-6-12-14V8l12-4z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M13 18l4 4 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/></svg>
              {%- when 'leaf' -%}
                <svg viewBox="0 0 36 36"><path d="M28 6c0 14-8 22-20 22 0-12 8-22 20-22z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M8 28L22 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/></svg>
              {%- when 'book' -%}
                <svg viewBox="0 0 36 36"><path d="M6 6h10a4 4 0 014 4v20a3 3 0 00-3-3H6V6z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M30 6H20a4 4 0 00-4 4v20a3 3 0 013-3h11V6z" stroke="currentColor" stroke-width="1.4" fill="none"/></svg>
              {%- when 'scissors' -%}
                <svg viewBox="0 0 36 36"><circle cx="9" cy="10" r="4" stroke="currentColor" stroke-width="1.4" fill="none"/><circle cx="9" cy="26" r="4" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M13 12l18 16M13 24L31 8" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round"/></svg>
              {%- else -%}
                <svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="14" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M13 18l4 4 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/></svg>
            {%- endcase -%}
          </div>
          <div class="kc-value__title">{{ block.settings.title }}</div>
          <div class="kc-value__sub">{{ block.settings.subtitle }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value bar",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "stitch", "label": "Stitch" },
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "shield", "label": "Shield (guarantee)" },
            { "value": "leaf", "label": "Leaf (natural)" },
            { "value": "book", "label": "Book" },
            { "value": "scissors", "label": "Scissors (handmade)" }
          ],
          "default": "stitch"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Saddle-stitched"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Every stitch pulled by hand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value bar",
      "blocks": [
        { "type": "value", "settings": { "icon": "scissors", "title": "Made by hand", "subtitle": "Cut, folded, stitched in small runs" }},
        { "type": "value", "settings": { "icon": "leaf", "title": "Full-grain leather", "subtitle": "Ages with you, softer every week" }},
        { "type": "value", "settings": { "icon": "truck", "title": "Free US shipping", "subtitle": "Orders over $75 ship on us" }},
        { "type": "value", "settings": { "icon": "shield", "title": "30-day returns", "subtitle": "Easy, no-questions policy" }}
      ]
    }
  ]
}
{% endschema %}
