<section class="kc-customer kc-customer--wide">
  <h1>{{ 'customer.addresses.title' | t }}</h1>
  <div style="text-align:center; margin-bottom:32px;">
    <a href="{{ routes.account_url }}" class="kc-link">← {{ 'customer.account.return' | t }}</a>
  </div>

  <div style="margin-bottom:40px;">
    <h2 style="font-size:22px; margin-bottom:16px;">{{ 'customer.addresses.add_new' | t }}</h2>
    {%- form 'customer_address', customer.new_address -%}
      {%- if form.errors -%}
        <div class="kc-notif kc-notif--error">
          <ul style="margin:0; padding-left:20px;">
            {%- for error in form.errors -%}<li>{{ form.errors.messages[error] }}</li>{%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
        <div class="kc-form-row"><label class="kc-label">{{ 'customer.addresses.first_name' | t }}</label><input type="text" name="address[first_name]" class="kc-field" value="{{ form.first_name }}"></div>
        <div class="kc-form-row"><label class="kc-label">{{ 'customer.addresses.last_name' | t }}</label><input type="text" name="address[last_name]" class="kc-field" value="{{ form.last_name }}"></div>
      </div>
      <div class="kc-form-row"><label class="kc-label">{{ 'customer.addresses.company' | t }}</label><input type="text" name="address[company]" class="kc-field" value="{{ form.company }}"></div>
      <div class="kc-form-row"><label class="kc-label">{{ 'customer.addresses.address1' | t }}</label><input type="text" name="address[address1]" class="kc-field" value="{{ form.address1 }}"></div>
      <div class="kc-form-row"><label class="kc-label">{{ 'customer.addresses.address2' | t }}</label><input type="text" name="address[address2]" class="kc-field" value="{{ form.address2 }}"></div>
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px;">
        <div class="kc-form-row"><label class="kc-label">{{ 'customer.addresses.city' | t }}</label><input type="text" name="address[city]" class="kc-field" value="{{ form.city }}"></div>
        <div class="kc-form-row"><label class="kc-label">{{ 'customer.addresses.zip' | t }}</label><input type="text" name="address[zip]" class="kc-field" value="{{ form.zip }}"></div>
        <div class="kc-form-row"><label class="kc-label">{{ 'customer.addresses.phone' | t }}</label><input type="tel" name="address[phone]" class="kc-field" value="{{ form.phone }}"></div>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
        <div class="kc-form-row">
          <label class="kc-label">{{ 'customer.addresses.country' | t }}</label>
          <select name="address[country]" class="kc-field" data-default="{{ form.country }}">{{ country_option_tags }}</select>
        </div>
        <div class="kc-form-row">
          <label class="kc-label">{{ 'customer.addresses.province' | t }}</label>
          <select name="address[province]" class="kc-field" data-default="{{ form.province }}"></select>
        </div>
      </div>
      <label style="display:flex; gap:10px; align-items:center; margin-bottom:20px; font-size:14px;">
        <input type="checkbox" name="address[default]" value="true"> {{ 'customer.addresses.set_default' | t }}
      </label>
      <button type="submit" class="kc-btn kc-btn--primary">{{ 'customer.addresses.add' | t }}</button>
    {%- endform -%}
  </div>

  {%- if customer.addresses.size > 0 -%}
    <h2 style="font-size:22px; margin-bottom:16px;">Saved</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:20px;">
      {%- for address in customer.addresses -%}
        <div style="padding:20px; background:var(--kc-cream); border-radius:var(--kc-r-md);">
          {%- if address == customer.default_address -%}
            <span class="kc-eyebrow" style="margin-bottom:10px; display:block;">{{ 'customer.addresses.default' | t }}</span>
          {%- endif -%}
          <address style="font-style:normal; font-size:14px; line-height:1.7; margin-bottom:14px;">{{ address | format_address }}</address>
          <div style="display:flex; gap:12px; font-size:12px;">
            <a href="#" onclick="this.closest('div[style]').querySelector('form').hidden = !this.closest('div[style]').querySelector('form').hidden; return false;" class="kc-link">Edit</a>
            {%- form 'customer_address', address -%}
              <button type="submit" name="_method" value="delete" onclick="return confirm('{{ 'customer.addresses.delete_confirm' | t }}')" class="kc-link" style="background:none; border:0; color:var(--kc-error);">Delete</button>
            {%- endform -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>
